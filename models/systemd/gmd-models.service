[Unit]
Description=gmd all models (vLLM) — embedding + expansion + rerank
Documentation=https://github.com/verdverm/gmd
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
Restart=on-failure
RestartSec=5

Environment="CUDA_VISIBLE_DEVICES=0"
Environment="GMD_EMBED_MODEL=google/embeddinggemma-300m"
Environment="GMD_EXPANSION_MODEL=Qwen/Qwen3-1.7B"
Environment="GMD_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B"
Environment="HF_HUB_CACHE=%h/.cache/huggingface"

ExecStart=bash -c '\
  vllm serve ${GMD_EMBED_MODEL} \
    --port 8001 --task embed --max-model-len 8192 --gpu-memory-utilization 0.30 & \
  vllm serve ${GMD_EXPANSION_MODEL} \
    --port 8002 --task generate --max-model-len 8192 --gpu-memory-utilization 0.30 & \
  vllm serve ${GMD_RERANK_MODEL} \
    --port 8003 --task rerank --max-model-len 8192 --gpu-memory-utilization 0.30 & \
  wait'

[Install]
WantedBy=default.target
