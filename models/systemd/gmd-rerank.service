[Unit]
Description=gmd rerank model (vLLM) — /v1/rerank
Documentation=https://github.com/verdverm/gmd
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
Restart=on-failure
RestartSec=5

Environment="CUDA_VISIBLE_DEVICES=0"
Environment="GMD_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B"
Environment="HF_HUB_CACHE=%h/.cache/huggingface"

ExecStart=vllm serve ${GMD_RERANK_MODEL} \
  --port 8003 \
  --task rerank \
  --max-model-len 8192 \
  --gpu-memory-utilization 0.30

[Install]
WantedBy=default.target
